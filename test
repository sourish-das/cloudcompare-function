4) Keep Export disabled when filters change
Prevents exporting stale results if the user changes inputs after “Compare”.


// in bootstrap(), with your other listeners:
[
  "os", "cpu", "ram", "storageType", "storageAmt",
  "awsFamily","azFamily","gcpFamily","ociProcessor"
].forEach(id => {
  const el = document.getElementById(id);
  if (!el) return;
  el.addEventListener("change", () => {
    const dl = document.getElementById("downloadPdfBtn");
    if (dl) dl.disabled = true; // force re-compare before export
  });
});
